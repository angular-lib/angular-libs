{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "@angular-libs/web": {
      "projectType": "library",
      "root": "projects/angular-libs/web",
      "sourceRoot": "projects/angular-libs/web/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/angular-libs/web/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/angular-libs/web/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/angular-libs/web/tsconfig.spec.json"
          }
        }
      }
    },
    "@angular-libs/dialog": {
      "projectType": "library",
      "root": "projects/angular-libs/dialog",
      "sourceRoot": "projects/angular-libs/dialog/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/angular-libs/dialog/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/angular-libs/dialog/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/angular-libs/dialog/tsconfig.spec.json"
          }
        }
      }
    },
    "@angular-libs/event-bus": {
      "projectType": "library",
      "root": "projects/angular-libs/event-bus",
      "sourceRoot": "projects/angular-libs/event-bus/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/angular-libs/event-bus/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/angular-libs/event-bus/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/angular-libs/event-bus/tsconfig.spec.json"
          }
        }
      }
    },
    "@angular-libs/store": {
      "projectType": "library",
      "root": "projects/angular-libs/store",
      "sourceRoot": "projects/angular-libs/store/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/angular-libs/store/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/angular-libs/store/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/angular-libs/store/tsconfig.spec.json"
          }
        }
      }
    },
    "@angular-libs/translate": {
      "projectType": "library",
      "root": "projects/angular-libs/translate",
      "sourceRoot": "projects/angular-libs/translate/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/angular-libs/translate/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/angular-libs/translate/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/angular-libs/translate/tsconfig.spec.json"
          }
        }
      }
    },
    "demo": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/demo",
      "sourceRoot": "projects/demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/demo/src/main.ts",
            "tsConfig": "projects/demo/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo/public"
              }
            ],
            "styles": ["projects/demo/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "demo:build:production"
            },
            "development": {
              "buildTarget": "demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
