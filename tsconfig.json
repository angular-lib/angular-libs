/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@angular-libs/dialog": ["./dist/angular-libs/dialog"],
      "@angular-libs/event-bus": ["./dist/angular-libs/event-bus"],
      "@angular-libs/store": ["./dist/angular-libs/store"],
      "@angular-libs/translate": ["./dist/angular-libs/translate"],
      "@angular-libs/web": ["./dist/angular-libs/web"]
    },
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/angular-libs/web/tsconfig.lib.json"
    },
    {
      "path": "./projects/angular-libs/web/tsconfig.spec.json"
    },
    {
      "path": "./projects/angular-libs/dialog/tsconfig.lib.json"
    },
    {
      "path": "./projects/angular-libs/dialog/tsconfig.spec.json"
    },
    {
      "path": "./projects/angular-libs/event-bus/tsconfig.lib.json"
    },
    {
      "path": "./projects/angular-libs/event-bus/tsconfig.spec.json"
    },
    {
      "path": "./projects/angular-libs/store/tsconfig.lib.json"
    },
    {
      "path": "./projects/angular-libs/store/tsconfig.spec.json"
    },
    {
      "path": "./projects/angular-libs/translate/tsconfig.lib.json"
    },
    {
      "path": "./projects/angular-libs/translate/tsconfig.spec.json"
    },
    {
      "path": "./projects/demo/tsconfig.app.json"
    },
    {
      "path": "./projects/demo/tsconfig.spec.json"
    }
  ]
}
